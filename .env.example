# Copy to .env and fill in. Get free keys at:
#   FRED:     https://fredaccount.stlouisfed.org/apikey
#   BEA:      https://apps.bea.gov/API/signup/
#   BLS:      https://data.bls.gov/registrationEngine/
#   e-Stat:   https://www.e-stat.go.jp/api/  (Japan CPI + SNA decomposition ports)
#   Destatis: https://www-genesis.destatis.de  (Germany decomposition port)
FRED_API_KEY=
BEA_API_KEY=
BLS_API_KEY=
ESTAT_API_ID=
# Germany (GENESIS): either name works; the token is on your GENESIS account page
DESTATIS_API_TOKEN=
# DESTATIS_API_KEY=
