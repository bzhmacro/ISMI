# ---- secrets (NEVER commit) ----
.env
*.key

# ---- python ----
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/
.eggs/
.venv/
venv/
.ipynb_checkpoints/

# ---- scratch / exploratory (kept locally, not part of the repo) ----
scratch/

# ---- data: caches & third-party files are NOT redistributed ----
# All raw pulls are reproducible from config/sources.yaml; regenerate locally.
data/raw/
data/processed/
# (the author-provided ISM_public.xlsx and BEA caches live under data/raw/ and
#  are intentionally excluded — see data/README.md for how to obtain them.)

# ---- the working paper PDF (do not redistribute; link via DOI in docs) ----
docs/*.pdf

# ---- generated outputs (figures/tables are regenerated by the notebooks) ----
outputs/

# ---- OS / editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/

# ---- web ----
# keep web/data/ism.json (demo) committed so the site renders out of the box;
# everything else under web/ is source.

# atomic-write / editor temp artifacts
*.tmp
*.tmp.*
*~
.*.swp

# vercel local project link
*.vercel/

# tests
.tests/
tests/

# Claude
.claude/